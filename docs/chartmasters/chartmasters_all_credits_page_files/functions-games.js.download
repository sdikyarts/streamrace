// 10-round Letters Game (same function name, same endpoints)
function initFindArtistsLettersGame() {
  const el = document.getElementById('cmg-artist-letters-container');
  if (!el) return;

  createRoundGame({
    container: el,
    loadAction: 'cmg_get_artistletters_letters',
    submitAction: 'cmg_submit_artistletters_score',

    onRenderQuestion: ({ data, round, answer }) => {
      // Require an answer and at least 5 letters
      if (!data || !data.answer || !Array.isArray(data.letters) || data.letters.length < 5) {
        el.innerHTML = resultShell('Letters data missing. Reload the page.');
        return;
      }

      const letters = data.letters.map(String);     // includes ' ' for space
      const target  = String(data.answer);          // normalized with spaces preserved
      let guess = [];
      const used = [];
      let hintCount = 0; // 0 -> none used, 1 -> first letter, 2 -> first+second

      el.innerHTML = `
        <div class="cmg-root cmg-center">
          ${qBadge((data.index ?? round) + 1)}

          <div id="letters" class="cmg-row"
               style="margin-top:6px;display:grid;grid-template-columns:repeat(5,minmax(44px,auto));gap:10px;justify-content:center">
            ${letters.map((ch,i)=>{
              const isSpace = ch === ' ';
              const label = isSpace ? '␣' : safe(ch);
              const payload = isSpace ? '__SPACE__' : safe(ch);
              return `<button class="cmg-btn l" data-i="${i}" data-c="${payload}" style="min-width:44px">${label}</button>`;
            }).join('')}
          </div>

          <div class="cmg-row" style="margin-top:8px">
            <div id="guess" class="cmg-badgelike" style="min-width:220px;text-align:center"></div>
          </div>

          <div class="cmg-row" style="margin-top:8px">
            <button class="cmg-btn" id="back">Delete</button>
            <button class="cmg-btn" id="clear">Clear</button>
            <button class="cmg-btn" id="validate">Validate</button>
          </div>

          <div class="cmg-row" style="margin-top:8px">
            <button class="cmg-btn" id="hint">Hint (2)</button>
          </div>

          <div id="fb" class="cmg-feedback cmg-center" style="margin-top:8px"></div>
        </div>
      `;

      // ---------- helpers ----------
      const guessEl = el.querySelector('#guess');
      const fb = el.querySelector('#fb');
      const btnHint = el.querySelector('#hint');

      function updateGuess(){ guessEl.textContent = guess.join(''); }
      function disableAll(){ el.querySelectorAll('button').forEach(b=>b.disabled=true); }
      function reenableAllTiles(){
        el.querySelectorAll('.l').forEach(b=>{ b.disabled = false; });
        used.length = 0;
      }
      function pickChar(ch){
        const want = (ch === ' ') ? '__SPACE__' : ch;
        const btn = Array.from(el.querySelectorAll('.l')).find(b => !b.disabled && b.dataset.c === want);
        if (!btn) return false;
        btn.disabled = true;
        used.push(btn);
        guess.push(ch);
        updateGuess();
        return true;
      }
      // Force first N chars of target into guess (resetting tiles)
      function setPrefix(n){
        reenableAllTiles();
        guess = [];
        for (let i=0;i<n;i++){
          if (!pickChar(target[i])) return false;
        }
        return true;
      }
      function updateHintLabel(){
        const left = Math.max(0, 2 - hintCount);
        btnHint.textContent = left ? `Hint (${left})` : 'Hint (0)';
        if (!left) btnHint.disabled = true;
      }

      // ---------- events ----------
      el.querySelectorAll('.l').forEach(btn=>{
        btn.onclick = () => {
          if (btn.disabled) return;
          btn.disabled = true;
          used.push(btn);
          const val = (btn.dataset.c === '__SPACE__') ? ' ' : btn.dataset.c;
          guess.push(val);
          updateGuess();
        };
      });

      el.querySelector('#back').onclick = () => {
        const b = used.pop();
        if (b){ b.disabled = false; guess.pop(); updateGuess(); }
      };

      el.querySelector('#clear').onclick = () => {
        reenableAllTiles();
        guess = [];
        updateGuess();
      };

      el.querySelector('#validate').onclick = () => {
        const ok = (guess.join('') === target);
        disableAll();
        fb.className = 'cmg-feedback ' + (ok ? 'cmg-correct' : 'cmg-wrong');
        fb.textContent = ok ? `✅ ${target}` : `❌ Correct: ${target}`;
        answer(ok);
      };

      btnHint.onclick = () => {
        if (hintCount >= 2) return;
        hintCount++;
        setPrefix(hintCount); // ensure first, then first+second
        updateHintLabel();
      };
      updateHintLabel();
      updateGuess();
    },

    onRenderFinish: ({ score, chart, total, userScore }) => {
      const id = 'cmg-artistletters-chart';
      el.innerHTML = resultShell(`
        <p>You scored ${score} out of 10!</p>
        <canvas id="${id}" class="cmg-chart"></canvas>
        <div class="cmg-row">${playMoreHTML()}</div>
      `);
      if (chart && total != null && userScore != null) {
        renderBarChart(id, chart, total, userScore);
      }
      share(el, `I scored ${score}/10 in the Letters game!`);
    }
  });
}

    // Who Has More Lead Streams? (A/B)
    function initMoreLeadStreamsGame() {
      const el = document.getElementById('cmg-moreleadstreams-container');
      if (!el) return;
      createRoundGame({
        container: el,
        loadAction: 'cmg_get_moreleadstreams_question',
        submitAction: 'cmg_submit_moreleadstreams_score',
        onRenderQuestion: ({data, answer}) => {
          el.innerHTML = `
            <div class="cmg-root cmg-center">
              <div class="cmg-row">
                ${['a','b'].map(k=>`
                  <div class="cmg-card" data-choice="${k.toUpperCase()}">
                    <img class="cmg-card__img" src="${safe(data[k].image)}" alt="${safe(data[k].name)}">
                    <p class="cmg-card__title">${safe(data[k].name)}</p>
                  </div>`).join('')}
              </div>
              <div id="fb" class="cmg-feedback cmg-center"></div>
            </div>`;
          el.querySelectorAll('.cmg-card').forEach(card=>{
            card.onclick=()=>{
              const guess = card.dataset.choice;
              const wasRight = guess === data.correct;
              const aName=data.a.name, bName=data.b.name;
              const aCount=fmtStreams(parseInt(data.s1,10)), bCount=fmtStreams(parseInt(data.s2,10));
              el.querySelectorAll('.cmg-card').forEach(c=>c.classList.add('is-disabled'));
              card.classList.add(wasRight?'correct':'wrong');
              const fb = el.querySelector('#fb');
              fb.className = 'cmg-feedback ' + (wasRight?'cmg-correct':'cmg-wrong');
              fb.innerHTML = `${wasRight?'✅':'❌'} ${safe(aName)}: ${aCount} lead streams<br>${safe(bName)}: ${bCount} lead streams`;
              answer(wasRight);
            };
          });
        },
        onRenderFinish: ({score, chart, total, userScore}) => {
          const id='cmg-leadstreams-chart';
          el.innerHTML = resultShell(`
            <p>🎯 ${COPY.scorePrefix} ${score} ${COPY.outOfTen}</p>
            <canvas id="${id}" class="cmg-chart""></canvas>
            <div class="cmg-row">${COPY.comeBackArtists}</div>
            <div class="cmg-row">${playMoreHTML()}</div>
          `);
          if (chart && total!=null && userScore!=null) renderBarChart(id, chart, total, userScore, '#3a86ff');
          share(el, `🎯 I scored ${score}/10 in Who Has More Lead Streams?`);
        }
      });
    }
    
    // Artist Sales Range (CSPC) — <20m ; 20-50m ; 50-100m ; 100m+
    function initArtistSalesGame() {
      const el = document.getElementById('cmg-artistsales-container');
      if (!el) return;
    
      const options = ['<20m','20-50m','50-100m','100m+'];
      const isPast = el.dataset.past === '1';
      const gameDate = el.dataset.date || null;
    
      createRoundGame({
        container: el,
        loadAction: 'cmg_get_artistsales_question',
        submitAction: isPast ? null : 'cmg_submit_artistsales_score',
        getLoadBody: () => (gameDate ? { date: gameDate } : {}),
    
        onRenderQuestion: ({ data: d, round, answer }) => {
          el.innerHTML = `
            <div class="cmg-root cmg-center">
              ${qBadge((d.index ?? round) + 1)}
              ${d.image_url ? `<img class="cmg-img" src="${safe(d.image_url)}" alt="${safe(d.artist)}">` : ''}
              <p class="cmg-title"><strong>${safe(d.artist)}</strong></p>
              <div class="cmg-row">
                ${options.map(o=>`<button class="cmg-btn range" data-v="${o}">${o}</button>`).join('')}
              </div>
              <div id="fb" class="cmg-feedback cmg-center"></div>
            </div>`;
    
          el.querySelectorAll('.range').forEach(btn=>{
            btn.onclick=()=>{
              const right = (d.bucket === btn.dataset.v);
              const fb = el.querySelector('#fb');
              fb.className = 'cmg-feedback ' + (right ? 'cmg-correct' : 'cmg-wrong');
              fb.innerHTML = right
                ? `✅ ${safe(d.artist)} totals ${fmtCspc(d.cspc)} CSPC.`
                : `❌ Correct bucket is ${safe(d.bucket)} (${fmtCspc(d.cspc)}).`;
              el.querySelectorAll('.range').forEach(b=>b.disabled=true);
              answer(right);
            };
          });
        },
    
        onRenderFinish: ({ score, chart, total, userScore }) => {
          if (isPast) {
            el.innerHTML = resultShell(`
              <p>🎯 ${COPY.scorePrefix} ${score} ${COPY.outOfTen}</p>
              <div class="cmg-row">${playMoreHTML()}</div>
            `);
            return;
          }
          const id='cmg-artistsales-chart';
          el.innerHTML = resultShell(`
            <p>🎯 ${COPY.scorePrefix} ${score} ${COPY.outOfTen}</p>
            <canvas id="${id}" class="cmg-chart"></canvas>
            <div class="cmg-row">${COPY.comeBackArtists}</div>
            <div class="cmg-row">${playMoreHTML()}</div>
          `);
          if (chart && total!=null && userScore!=null) renderBarChart(id, chart, total, userScore, '#3a86ff');
          share(el, `🎯 I scored ${score}/10 in Artist Sales Range!`);
        }
      });
    }

    
    // ================== Bootstrapping (gated start) ==================
    window.addEventListener('load', () => {
      if (document.getElementById('cmg-game-container'))
        gateGame('cmg-game-container', initGuessAlbumGame, {
          image: '/wp-content/uploads/2025/08/Logo-Find-album-title.jpg'
        });
    
      if (document.getElementById('cmg-overunder-container'))
        gateGame('cmg-overunder-container', initOverUnderGame, {
          image: '/wp-content/uploads/2025/08/Logo-Song-streams.jpg'
        });
    
      if (document.getElementById('cmg-albumstreams-container'))
        gateGame('cmg-albumstreams-container', initAlbumStreamsGame, {
          image: '/wp-content/uploads/2025/08/Logo-Album-streams.jpg'
        });
    
      if (document.getElementById('cmg-artist-letters-container'))
        gateGame('cmg-artist-letters-container', initFindArtistsLettersGame, {
          image: '/wp-content/uploads/2025/08/Logo-Find-artist-names.jpg'
        });
    
      if (document.getElementById('cmg-morelisteners-container'))
        gateGame('cmg-morelisteners-container', initMoreListenersGame, {
          image: '/wp-content/uploads/2025/08/Logo-Most-monthly-listeners.jpg'
        });
    
      if (document.getElementById('cmg-cspc-overunder-container'))
        gateGame('cmg-cspc-overunder-container', initCspcOverUnderGame, {
          image: '/wp-content/uploads/2025/08/Logo-Album-10M.jpg'
        });
    
      if (document.getElementById('cmg-morefollows-container'))
        gateGame('cmg-morefollows-container', initMoreFollowersGame, {
          image: '/wp-content/uploads/2025/08/Logo-Most-followers.jpg'
        });
    
      if (document.getElementById('cmg-biggesthit-container'))
        gateGame('cmg-biggesthit-container', initBiggestHitGame, {
          image: '/wp-content/uploads/2025/08/Logo-Biggest-hit-from-album.jpg'
        });
    
      if (document.getElementById('cmg-firstsecond-container'))
        gateGame('cmg-firstsecond-container', initFirstSecondHitGame, {
          image: '/wp-content/uploads/2025/08/Logo-Biggest-hit-or-runner-up.jpg'
        });
    
      if (document.getElementById('cmg-fakealbum-container'))
        gateGame('cmg-fakealbum-container', initFindFakeAlbumGame, {
          image: '/wp-content/uploads/2025/08/Logo-Spot-the-odd-one-out.jpg'
        });
    
      if (document.getElementById('cmg-moreleadstreams-container'))
        gateGame('cmg-moreleadstreams-container', initMoreLeadStreamsGame, {
          image: '/wp-content/uploads/2025/08/Logo-Artist-streams.jpg'
        });
    
      if (document.getElementById('cmg-artistsales-container'))
        gateGame('cmg-artistsales-container', initArtistSalesGame, {
          image: '/wp-content/uploads/2025/08/Logo-Artist-sales.jpg'
        });
    });


})();
