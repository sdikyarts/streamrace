            fb.className = 'cmg-feedback ' + (wasRight?'cmg-correct':'cmg-wrong');
            fb.innerHTML = wasRight ? `✅ ${safe(correctVal)} was the fake album.` : `❌ Fake album was ${safe(correctVal)}.`;
            el.querySelectorAll('.f').forEach(x=>x.disabled=true);
            answer(wasRight);
          };
        });
      },
      onRenderFinish: ({score, chart, total, userScore}) => {
        const id='cmg-fakealbum-chart';
        el.innerHTML = resultShell(`
          <p>🎯 ${COPY.scorePrefix} ${score} ${COPY.outOfTen}</p>
          <canvas id="${id}" class="cmg-chart"></canvas>
          <div class="cmg-row">${playMoreHTML()}</div>
        `);
        if (chart && total!=null && userScore!=null) renderBarChart(id, chart, total, userScore, '#e67e22');
        share(el, `🎯 I scored ${score}/10 in Find the Fake Album!`);
      }
    });
  }

